{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "青锁盾",
  "mainBinaryName": "青锁盾",
  "version": "1.0.0",
  "identifier": "com.jtstudio.growguard",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "青锁盾 · 青少年访问锁",
        "width": 940,
        "height": 720,
        "minWidth": 820,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
